# ==============================================
# EvalMind - Environment Variables
# ==============================================
# Copy this file to .env and fill in your values: cp .env.example .env

# ---------- MySQL Database ----------
MYSQL_ROOT_PASSWORD=root_password
MYSQL_DATABASE=agent_eval_platform
MYSQL_USER=agent_eval
MYSQL_PASSWORD=agent_eval_pass

# Prisma database connection string
# For local development: use "localhost"
DATABASE_URL=mysql://agent_eval:agent_eval_pass@localhost:3306/agent_eval_platform
# For Docker Compose: use "mysql" as hostname (the service name)
# DATABASE_URL=mysql://agent_eval:agent_eval_pass@mysql:3306/agent_eval_platform

# ---------- Judge LLM Configuration ----------
# LLM model used for evaluation scoring.
# Choose ONE provider below and fill in your API key.
# Any OpenAI Chat Completions API compatible service is supported.

# --- OpenAI ---
# JUDGE_LLM_BASE_URL=https://api.openai.com/v1
# JUDGE_LLM_API_KEY=sk-your-openai-key
# JUDGE_LLM_MODEL=gpt-4o

# --- DeepSeek ---
# JUDGE_LLM_BASE_URL=https://api.deepseek.com/v1
# JUDGE_LLM_API_KEY=sk-your-deepseek-key
# JUDGE_LLM_MODEL=deepseek-chat

# --- Anthropic Claude ---
# JUDGE_LLM_BASE_URL=https://api.anthropic.com/v1
# JUDGE_LLM_API_KEY=sk-ant-your-anthropic-key
# JUDGE_LLM_MODEL=claude-sonnet-4-20250514

# --- Google Gemini ---
# JUDGE_LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
# JUDGE_LLM_API_KEY=your-google-api-key
# JUDGE_LLM_MODEL=gemini-2.0-flash

# --- Local Ollama (no API key needed) ---
# JUDGE_LLM_BASE_URL=http://localhost:11434/v1
# JUDGE_LLM_API_KEY=ollama
# JUDGE_LLM_MODEL=qwen2.5:14b

# Uncomment and fill ONE provider:
JUDGE_LLM_BASE_URL=
JUDGE_LLM_API_KEY=
JUDGE_LLM_MODEL=

# ---------- CORS Configuration ----------
# Allowed origins, separate multiple with commas
CORS_ORIGINS=*

# ---------- Logging ----------
LOG_LEVEL=INFO
