# ==============================================
# EvalMind - Environment Variables
# ==============================================
# Copy this file to .env and fill in your values: cp .env.example .env

# ---------- MySQL Database ----------
MYSQL_ROOT_PASSWORD=root_password
MYSQL_DATABASE=agent_eval_platform
MYSQL_USER=agent_eval
MYSQL_PASSWORD=agent_eval_pass

# Prisma database connection string
# For local development: use "localhost"
DATABASE_URL=mysql://agent_eval:agent_eval_pass@localhost:3306/agent_eval_platform
# For Docker Compose: use "mysql" as hostname (the service name)
# DATABASE_URL=mysql://agent_eval:agent_eval_pass@mysql:3306/agent_eval_platform

# ---------- Judge LLM Configuration ----------
# LLM model used for evaluation scoring
JUDGE_LLM_BASE_URL=https://api.deepseek.com/v1
JUDGE_LLM_API_KEY=your-api-key-here
JUDGE_LLM_MODEL=deepseek-chat

# ---------- CORS Configuration ----------
# Allowed origins, separate multiple with commas
CORS_ORIGINS=*

# ---------- Logging ----------
LOG_LEVEL=INFO
