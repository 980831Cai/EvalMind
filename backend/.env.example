# Platform Configuration
DATABASE_URL="mysql://agent_eval:agent_eval_pass@localhost:3306/agent_eval_platform"

# LLM-as-Judge Configuration (OpenAI Chat Completions API compatible format)
# Supports: OpenAI / DeepSeek / Anthropic / Google Gemini / Ollama / vLLM / any OpenAI-compatible service
# JUDGE_LLM_BASE_URL: API base URL (up to /v1, without /chat/completions)
# JUDGE_LLM_API_KEY: Your API key
# JUDGE_LLM_MODEL: Model name to use
#
# --- Example: OpenAI ---
# JUDGE_LLM_BASE_URL=https://api.openai.com/v1
# JUDGE_LLM_API_KEY=sk-your-openai-key
# JUDGE_LLM_MODEL=gpt-4o
#
# --- Example: DeepSeek ---
# JUDGE_LLM_BASE_URL=https://api.deepseek.com/v1
# JUDGE_LLM_API_KEY=sk-your-deepseek-key
# JUDGE_LLM_MODEL=deepseek-chat
#
# --- Example: Anthropic Claude ---
# JUDGE_LLM_BASE_URL=https://api.anthropic.com/v1
# JUDGE_LLM_API_KEY=sk-ant-your-anthropic-key
# JUDGE_LLM_MODEL=claude-sonnet-4-20250514
#
# --- Example: Google Gemini ---
# JUDGE_LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
# JUDGE_LLM_API_KEY=your-google-api-key
# JUDGE_LLM_MODEL=gemini-2.0-flash
#
# --- Example: Local Ollama (no API key needed) ---
# JUDGE_LLM_BASE_URL=http://localhost:11434/v1
# JUDGE_LLM_API_KEY=ollama
# JUDGE_LLM_MODEL=qwen2.5:14b
#
# Uncomment and fill ONE provider:
JUDGE_LLM_BASE_URL=
JUDGE_LLM_API_KEY=
JUDGE_LLM_MODEL=

# Ingest API authentication key (for external SDK data ingestion)
INGEST_API_KEY=

# Allowed CORS origins (comma-separated, set specific domains in production)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
