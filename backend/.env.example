# Platform Configuration
DATABASE_URL="mysql://agent_eval:your-db-password@localhost:3306/agent_eval_platform"

# LLM-as-Judge Configuration (OpenAI Chat Completions API compatible format)
# Supports: OpenAI / DeepSeek / Ollama / vLLM / Azure OpenAI / any OpenAI-compatible service
# JUDGE_LLM_BASE_URL: API base URL (up to /v1, without /chat/completions)
# JUDGE_LLM_API_KEY: API Key
# JUDGE_LLM_MODEL: Model name to use
#
# --- Example: OpenAI ---
# JUDGE_LLM_BASE_URL=https://api.openai.com/v1
# JUDGE_LLM_API_KEY=sk-xxx
# JUDGE_LLM_MODEL=gpt-4o
#
# --- Example: DeepSeek ---
# JUDGE_LLM_BASE_URL=https://api.deepseek.com/v1
# JUDGE_LLM_API_KEY=sk-xxx
# JUDGE_LLM_MODEL=deepseek-chat
#
# --- Example: Local Ollama ---
# JUDGE_LLM_BASE_URL=http://localhost:11434/v1
# JUDGE_LLM_API_KEY=ollama
# JUDGE_LLM_MODEL=qwen2.5:14b
#
JUDGE_LLM_BASE_URL=https://api.deepseek.com/v1
JUDGE_LLM_API_KEY=your-api-key-here
JUDGE_LLM_MODEL=deepseek-chat

# Ingest API authentication key (for external SDK data ingestion)
INGEST_API_KEY=your-ingest-api-key

# Allowed CORS origins (comma-separated, set specific domains in production)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
